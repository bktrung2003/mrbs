# Copy to .env and adjust for your environment.
# Portainer: set these as stack environment variables.

DOMAIN=localhost
FRONTEND_HOST=http://localhost
ENVIRONMENT=production
TIMEZONE=Asia/Ho_Chi_Minh

PROJECT_NAME=Fusion Hotel Group MRBS
STACK_NAME=mrbs

# Comma-separated origins allowed by the API (include your public URL)
BACKEND_CORS_ORIGINS=http://localhost,http://localhost:80,http://localhost:8000

SECRET_KEY=changethis-generate-a-long-random-string
FIRST_SUPERUSER=admin@example.com
FIRST_SUPERUSER_PASSWORD=changethis

SMTP_HOST=
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=noreply@example.com
SMTP_TLS=True
SMTP_SSL=False
SMTP_PORT=587

POSTGRES_SERVER=db
POSTGRES_PORT=5432
POSTGRES_DB=mrbs
POSTGRES_USER=mrbs
POSTGRES_PASSWORD=changethis-db-password

SENTRY_DSN=

# GHCR images (built by GitHub Actions)
DOCKER_IMAGE_BACKEND=ghcr.io/bktrung2003/mrbs-backend
DOCKER_IMAGE_FRONTEND=ghcr.io/bktrung2003/mrbs-frontend
TAG=latest

# Used when building the frontend image in CI (set GitHub repo variable VITE_API_URL)
# Example: https://mrbs-api.yourdomain.com or http://your-server-ip:8000
VITE_API_URL=http://localhost:8000

# Optional host ports (compose.portainer.yml)
BACKEND_PORT=8000
FRONTEND_PORT=80
