# Paste into Portainer stack → Environment variables (or upload as .env file).
# Replace values below before deploy.

# Required — must NOT be "changethis" in production
DB_PASSWORD=your-strong-db-password
SECRET_KEY=your-long-random-secret-key
FIRST_SUPERUSER_PASSWORD=your-admin-password

# Public URL users open in browser (include port)
FRONTEND_URL=http://192.168.1.22:3014

# GitHub Actions variable VITE_API_URL must match backend host port:
# http://192.168.1.22:8014

# Optional — email
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# EMAILS_FROM_EMAIL=noreply@example.com
